{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": { "EAS_BUILD_NO_EXPO_GO_WARNING": "true" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EAS_BUILD_NO_EXPO_GO_WARNING": "true" }
    }
  },
  "submit": {
    "production": {}
  }
}
